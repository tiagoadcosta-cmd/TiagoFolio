:root{--text-xs:clamp(.75rem,.7rem + .25vw,.875rem);--text-sm:clamp(.875rem,.8rem + .35vw,1rem);--text-base:clamp(1rem,.95rem + .25vw,1.125rem);--space-2:.5rem;--space-3:.75rem;--space-4:1rem;--space-6:1.5rem;--space-8:2rem;--space-10:2.5rem;--color-bg:#0f1012;--color-text:#f3f4f6;--color-text-muted:#b0b5bc;--color-border:rgba(255,255,255,.1);--radius-full:9999px;--shadow-md:0 12px 32px rgba(0,0,0,.22);--transition-interactive:500ms cubic-bezier(.16,1,.3,1);--font-body:'General Sans',Inter,sans-serif;--font-display:'Cabinet Grotesk',Inter,sans-serif;--scene-baseline:150px;}
*{box-sizing:border-box;margin:0;padding:0}html{scroll-behavior:smooth}body{min-height:100dvh;font-family:var(--font-body);font-size:var(--text-base);line-height:1.6;color:var(--color-text);background:var(--color-bg);overflow-x:hidden}img{display:block;max-width:100%}a,button{transition:all var(--transition-interactive)}a{text-decoration:none;color:inherit}.skip-link{position:absolute;left:-9999px}.skip-link:focus{left:var(--space-4);top:var(--space-4);z-index:100;background:#4f98a3;color:#061115;padding:var(--space-3) var(--space-4);border-radius:.5rem}.page-background{position:fixed;inset:0;z-index:-3;background-image:linear-gradient(180deg,rgba(8,10,14,.08),rgba(8,10,14,.24)),url('./road.png');background-size: 320px auto, 100% 100%;background-position: 0 bottom, center bottom;background-repeat:repeat-x}.site-header{position:fixed;top:0;left:0;right:0;z-index:20;display:flex;align-items:center;justify-content:space-between;padding:var(--space-4) var(--space-6);pointer-events:none}.site-header>*{pointer-events:auto}.brand-mark{color:var(--color-text);font-size:1.2rem;font-weight:700}.sound-toggle{color:var(--color-text-muted);background:rgba(22,24,27,.78);border:1px solid var(--color-border);padding:.7rem 1rem;border-radius:var(--radius-full);backdrop-filter:blur(8px)}.experience-shell,.road-stage,.horizontal-viewport{min-height:100vh}.road-stage{position:relative}.scene-layer{position:fixed;inset:0;z-index:2;pointer-events:none}.scene-debug-line{position:absolute;left:0;right:0;bottom:var(--scene-baseline);border-top:1px dashed rgba(79,152,163,.45)}.car-lane{position:fixed;left:0;right:0;bottom:5px;z-index:6;pointer-events:none}.car-wrapper{position:absolute;left:clamp(1.5rem,7vw,8rem);bottom:12px;width:min(512px,58vw);aspect-ratio:3 / 1.3;transform-origin:center bottom;will-change:transform}.car-image{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;opacity:0;transition:opacity 180ms ease}.car-image-wheel1, .car-image-wheel2 { z-index: 2; transform: scaleX(var(--wheel-flip,1)) rotateY(var(--wheel-rotate,0deg)); will-change: transform; }.car-image-on { z-index: 1; }.car-wrapper[data-car-state="off"] .car-image-off{opacity:1}.car-wrapper[data-car-state="on"] .car-image-on.is-active-frame, .car-wrapper[data-car-state="on"] .car-image-wheel1, .car-wrapper[data-car-state="on"] .car-image-wheel2 {opacity:1}.car-wrapper[data-car-state="reverse"] .car-image-on, .car-wrapper[data-car-state="reverse"] .car-image-wheel1, .car-wrapper[data-car-state="reverse"] .car-image-wheel2 {opacity:1}.car-wrapper[data-car-state="reverse"] .car-image-wheel1, .car-wrapper[data-car-state="reverse"] .car-image-wheel2 { --wheel-flip: -1; }.horizontal-track{display:flex;width:max-content}.panel{width:100vw;min-height:100vh;display:flex;align-items:flex-start;justify-content:flex-end;padding:15vh clamp(4rem,8vw,10rem) 0 0}.panel--ghost{background:transparent}.road-card{width:min(700px,78vw);opacity:0;transform:translateY(18px) scale(.98);transition:opacity 500ms ease,transform 500ms ease;position:relative;right:clamp(2rem,5vw,5rem);left:auto}.road-card.is-visible{opacity:1;transform:translateY(0) scale(1)}.road-card-inner{background:rgba(16,18,22,.82);border:1px solid rgba(255,255,255,.1);border-radius:1rem;padding:clamp(1.5rem,3vw,2.25rem);box-shadow:var(--shadow-md);backdrop-filter:blur(12px)}.eyebrow{font-size:var(--text-xs);text-transform:uppercase;letter-spacing:.16em;color:#76b8c2;margin-bottom:var(--space-4)}.road-card h1,.road-card h2{font-family:var(--font-display);line-height:1.05;margin-bottom:var(--space-4)}.road-card h1{font-size:clamp(2rem,4vw,3.5rem)}.road-card h2{font-size:clamp(1.75rem,3vw,2.75rem)}.scene-copy{color:var(--color-text-muted);max-width:64ch}.chip-row,.contact-list{display:flex;flex-wrap:wrap;gap:var(--space-3);margin-top:var(--space-6)}.chip-row span,.contact-list a{border:1px solid var(--color-border);background:rgba(255,255,255,.02);border-radius:var(--radius-full);padding:.8rem 1rem;color:var(--color-text-muted)}.bottom-nav{position:fixed;left:50%;bottom:var(--space-4);transform:translateX(-50%);z-index:20;display:flex;gap:var(--space-2);flex-wrap:wrap;justify-content:center;padding:var(--space-2);background:rgba(20,22,25,.8);border:1px solid var(--color-border);border-radius:var(--radius-full);backdrop-filter:blur(12px)}.bottom-nav a{padding:.7rem .95rem;border-radius:var(--radius-full);color:var(--color-text-muted);font-size:var(--text-sm)}.bottom-nav a.is-active,.bottom-nav a:hover{color:var(--color-text);background:rgba(255,255,255,.06)}@media (max-width:900px){.page-background{background-size:180px auto;background-position: 0 bottom, center bottom}.car-wrapper{width:min(360px,78vw);bottom:8px}.road-card{width:min(90vw,700px);right:1rem;left:auto}.panel{padding:10vh 1rem}}